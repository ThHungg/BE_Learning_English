# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3333

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_HOST_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=learning_english

# ============================================
# JWT CONFIGURATION
# ============================================
