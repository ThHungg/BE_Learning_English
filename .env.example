JWT_EXPIRY=7d

# ============================================
# API KEY CONFIGURATION
# ============================================
API_KEY=your_super_secret_api_key_change_this_in_production

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=development
